Bootstrap: docker
From: rocm/dev-ubuntu-22.04:6.4

%labels
    Author aneurysm_cnn
    ROCm   6.4
    Python 3.11

%post
    # ------------------------------------------------------------------ #
    #  System packages                                                     #
    # ------------------------------------------------------------------ #
    apt-get update -y && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-dev \
        python3.11-distutils \
        python3-pip \
        curl \
        && rm -rf /var/lib/apt/lists/*

    # Make python3.11 the default python3/python
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1
    update-alternatives --install /usr/bin/python  python  /usr/bin/python3.11 1

    # Upgrade pip
    python -m pip install --upgrade pip

    # ------------------------------------------------------------------ #
    #  PyTorch + torchvision — ROCm 6.4 wheels                           #
    # ------------------------------------------------------------------ #
    pip install torch==2.9.1 torchvision==0.24.1 \
        --index-url https://download.pytorch.org/whl/rocm6.4

    # ------------------------------------------------------------------ #
    #  Project dependencies                                               #
    # ------------------------------------------------------------------ #
    pip install \
        "monai>=1.3.1" \
        einops \
        nibabel \
        numpy \
        pandas \
        scikit-learn \
        matplotlib \
        tqdm \
        pytest \
        ruff

%environment
    # Required for AMD Instinct MI210 (gfx90a) — tells ROCm to treat the
    # GPU as gfx90a even when the runtime reports a different string.
    export HSA_OVERRIDE_GFX_VERSION=9.0.10

    # Ensure the container's Python is used
    export PATH=/usr/bin:$PATH

%runscript
    exec python "$@"

%help
    Singularity container for aneurysm_cnn training on AMD GPUs.

    Build (run on a machine with sudo or fakeroot):
        singularity build aneurysm_cnn_rocm.sif hpc/singularity/aneurysm_cnn_rocm.def

    Quick GPU test on the cluster:
        singularity exec --rocm aneurysm_cnn_rocm.sif python -c \
            "import torch; print(torch.cuda.is_available(), torch.cuda.get_device_name(0))"

    Submit training job:
        sbatch hpc/singularity/start_script_rocm.slurm
